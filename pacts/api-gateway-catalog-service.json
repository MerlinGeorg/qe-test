{
  "consumer": {
    "name": "api-gateway"
  },
  "interactions": [
    {
      "description": "a request for a nonexistent product",
      "providerStates": [
        {
          "name": "product nonexistent does not exist"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/products/nonexistent"
      },
      "response": {
        "body": {
          "error": "Product not found"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 404
      }
    },
    {
      "description": "a request for product sku-123",
      "providerStates": [
        {
          "name": "product sku-123 exists"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/products/sku-123"
      },
      "response": {
        "body": {
          "category": "accessories",
          "currency": "CAD",
          "id": "sku-123",
          "name": "Wireless Keyboard",
          "price": 79.99
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "17.0.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "catalog-service"
  }
}