{
  "consumer": {
    "name": "api-gateway"
  },
  "interactions": [
    {
      "description": "a request for availability of a nonexistent product",
      "providerStates": [
        {
          "name": "no inventory record for sku-nonexistent"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/products/sku-nonexistent/availability"
      },
      "response": {
        "body": {
          "error": "Inventory record not found"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 404
      }
    },
    {
      "description": "a request for sku-123 availability",
      "providerStates": [
        {
          "name": "sku-123 is in stock"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/products/sku-123/availability"
      },
      "response": {
        "body": {
          "available": true,
          "productId": "sku-123",
          "quantity": 42,
          "reserved": 3,
          "warehouse": "TOR-01"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "17.0.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "inventory-service"
  }
}