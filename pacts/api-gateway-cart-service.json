{
  "consumer": {
    "name": "api-gateway"
  },
  "interactions": [
    {
      "description": "a request to add sku-456 to user-123 cart",
      "providerStates": [
        {
          "name": "product sku-456 exists in catalog"
        }
      ],
      "request": {
        "body": {
          "productId": "sku-456",
          "quantity": 2
        },
        "headers": {
          "Content-Type": "application/json",
          "x-user-id": "user-123"
        },
        "method": "POST",
        "path": "/items"
      },
      "response": {
        "body": {
          "items": [
            {
              "currency": "CAD",
              "productId": "sku-456",
              "quantity": 2,
              "unitPrice": 149.99
            }
          ],
          "summary": {
            "currency": "CAD",
            "itemCount": 2,
            "subtotal": 299.98
          },
          "userId": "user-123"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.summary": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 201
      }
    },
    {
      "description": "a request to get cart items for user-123",
      "providerStates": [
        {
          "name": "user-123 has items in their cart"
        }
      ],
      "request": {
        "headers": {
          "x-user-id": "user-123"
        },
        "method": "GET",
        "path": "/items"
      },
      "response": {
        "body": {
          "items": [
            {
              "currency": "CAD",
              "name": "Wireless Keyboard",
              "productId": "sku-123",
              "quantity": 1,
              "unitPrice": 79.99
            }
          ],
          "summary": {
            "currency": "CAD",
            "itemCount": 1,
            "subtotal": 79.99
          },
          "userId": "user-123"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.summary": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "17.0.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "cart-service"
  }
}