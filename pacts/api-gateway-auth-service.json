{
  "consumer": {
    "name": "api-gateway"
  },
  "interactions": [
    {
      "description": "a login request with valid credentials",
      "providerStates": [
        {
          "name": "customer@example.com exists with password secret"
        }
      ],
      "request": {
        "body": {
          "email": "customer@example.com",
          "password": "secret"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/login"
      },
      "response": {
        "body": {
          "accessToken": "some.jwt.token",
          "expiresIn": 3600,
          "tokenType": "Bearer",
          "user": {
            "email": "customer@example.com",
            "firstName": "Casey",
            "id": "user-123",
            "lastName": "Nguyen"
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a login request with wrong password",
      "providerStates": [
        {
          "name": "invalid credentials are provided"
        }
      ],
      "request": {
        "body": {
          "email": "customer@example.com",
          "password": "wrongpassword"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/login"
      },
      "response": {
        "body": {
          "error": "Invalid email or password"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 401
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "17.0.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "auth-service"
  }
}